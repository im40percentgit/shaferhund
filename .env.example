# Claude API — required; get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Dashboard auth — unset binds the dashboard to 127.0.0.1 only (safe default)
SHAFERHUND_TOKEN=

# Wazuh manager REST API credentials.
# The default upstream password is well-known; set your own before first start.
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=REPLACE_ME_BEFORE_FIRST_START

# Claude model selection
CLAUDE_MODEL=claude-opus-4-5

# --- Wazuh source ---
# Path to alerts.json inside the agent container (mounted from wazuh_logs volume)
ALERTS_FILE=/var/ossec/logs/alerts/alerts.json
# Only forward alerts at or above this Wazuh severity level (0-15)
SEVERITY_MIN_LEVEL=7

# --- Suricata source ---
# Path to Suricata eve.json inside the agent container (mounted from suricata_logs volume)
SURICATA_EVE_FILE=/var/log/suricata/eve.json
# How often to poll the Suricata eve.json file (seconds)
SURICATA_POLL_SECONDS=60

# --- Triage budget and polling ---
# Maximum Claude API calls per hour across all clusters
TRIAGE_HOURLY_BUDGET=20
# How often to poll the Wazuh alerts.json file (seconds)
POLL_INTERVAL_SECONDS=60

# --- Clustering ---
# Maximum alerts stored per cluster before the cluster is split
CLUSTER_MAX_ALERTS=50
# Time window for grouping alerts into a cluster (seconds)
CLUSTER_WINDOW_SECONDS=300

# --- Queue ---
# Maximum number of clusters held in the triage queue; oldest dropped when full
QUEUE_MAX_DEPTH=100

# --- Storage ---
# SQLite database path inside the agent container
DB_PATH=/data/shaferhund.db
# Directory where generated YARA rule files are written
RULES_DIR=/rules

# --- Orchestrator caps (per cluster) ---
# Maximum tool calls Claude may make in a single triage loop
ORCH_MAX_TOOL_CALLS=5
# Wall-clock timeout for the entire orchestrator loop (seconds)
ORCH_WALL_TIMEOUT_SECONDS=10

# --- Auto-deploy policy gate (default OFF) ---
# Set to true to allow high-confidence rules to deploy automatically
AUTO_DEPLOY_ENABLED=false
# Minimum confidence score required for auto-deploy (0.0–1.0)
AUTO_DEPLOY_CONF_THRESHOLD=0.85
# Deduplication window: skip auto-deploy if a similar rule deployed within this window (seconds)
AUTO_DEPLOY_DEDUP_WINDOW_SECONDS=3600
# JSON-encoded list of severity levels eligible for auto-deploy
AUTO_DEPLOY_SEVERITIES=["Critical","High"]

# --- Phase 3: Threat Intelligence (URLhaus, REQ-P0-P3-005) ---
# URLhaus online-URL CSV feed. Override to use a mirror or air-gapped copy.
URLHAUS_FEED_URL=https://urlhaus.abuse.ch/downloads/csv_online/
# How often to refresh the threat_intel table from the feed (seconds). Default: 3600 (hourly).
URLHAUS_FETCH_INTERVAL_SECONDS=3600

# --- Phase 3: Canary tokens (REQ-P0-P3-004) ---
# Base URL used to build HTTP canary trap URLs returned by POST /canary/spawn.
# Override with the public hostname/IP where Shaferhund is reachable so external
# attackers can hit the /canary/hit/{token} route.
CANARY_BASE_URL=http://127.0.0.1:8000
# Base hostname suffix for DNS canary trap hostnames ({token}.{CANARY_BASE_HOSTNAME}).
# For DNS traps to fire, configure a wildcard DNS record pointing to your sensor
# or enable Wazuh DNS query monitoring on the canary.local zone.
CANARY_BASE_HOSTNAME=canary.local

# --- Phase 3: Atomic Red Team posture scheduling (REQ-P0-P3-001) ---
# Seconds between automatic posture runs. 0 = ad-hoc only (POST /posture/run).
# Typical values: 0 (manual), 3600 (hourly), 86400 (daily).
POSTURE_RUN_SCHEDULE_SECONDS=0
# Name of the redteam-target container (the compose service name).
REDTEAM_TARGET_CONTAINER=redteam-target
# Path to the declarative ART test list (DEC-REDTEAM-002, no auto-discovery).
ART_TESTS_FILE=atomic_tests.yaml
